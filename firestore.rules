rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }

    function myPapel() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.papel;
    }
    function isGestor() { return isAuth() && myPapel() == "gestor"; }

    // ── reports ──────────────────────────────────────────────
    match /reports/{id} {
      allow read: if isAuth() && (
        isGestor() || resource.data.createdBy == request.auth.uid
      );
      allow create: if isAuth() &&
        request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuth() && (
        isGestor() || resource.data.createdBy == request.auth.uid
      );
      allow delete: if isGestor();
    }

    // ── users ─────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth() && (request.auth.uid == uid || isGestor());
      allow create, update: if isAuth() && request.auth.uid == uid;
      allow update: if isGestor();
      allow delete: if isGestor();
    }
  }
}
